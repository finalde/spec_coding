{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "http://spec-coding/plan.schema.json",
  "title": "Spec-coding execution plan",
  "type": "object",
  "required": ["metadata", "work_units", "acceptance_checks", "revision_policy"],
  "additionalProperties": true,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["task_id", "root_folder", "spec_ref"],
      "properties": {
        "task_id": { "type": "string" },
        "root_folder": { "enum": ["projects", "ai_videos"] },
        "output_root": { "type": "string" },
        "created_at": { "type": "string" },
        "spec_ref": { "type": "string" },
        "dossier_ref": { "type": ["string", "null"] },
        "adjustments_ref": { "type": ["string", "null"] },
        "conventions_ref": { "type": "string" }
      }
    },
    "globals": {
      "type": "object",
      "properties": {
        "language": { "type": "string" },
        "test_command": { "type": ["string", "null"] },
        "build_command": { "type": ["string", "null"] }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^R-\\d+$" },
          "description": { "type": "string" },
          "mitigation": { "type": "string" }
        }
      }
    },
    "work_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "description", "outputs"],
        "properties": {
          "id": { "type": "string", "pattern": "^WU-\\d+$" },
          "type": { "enum": ["code", "writer", "architect", "asset"] },
          "description": { "type": "string" },
          "inputs": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "pattern": "^WU-\\d+$" }
          },
          "tools_allowed": {
            "type": "array",
            "items": {
              "enum": ["Read", "Write", "Edit", "Bash", "Grep", "Glob", "WebSearch", "WebFetch"]
            }
          },
          "acceptance_checks": {
            "type": "array",
            "items": { "type": "string", "pattern": "^AC-" }
          }
        }
      }
    },
    "acceptance_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "spec"],
        "properties": {
          "id": { "type": "string", "pattern": "^AC-" },
          "kind": { "enum": ["unit_test", "grep", "file_exists", "cmd", "llm_review"] },
          "spec": { "type": "object" }
        }
      }
    },
    "revision_policy": {
      "type": "object",
      "required": ["max_iterations", "on_block"],
      "properties": {
        "max_iterations": { "type": "integer", "minimum": 1, "maximum": 10 },
        "on_block": { "enum": ["escalate", "halt"] }
      }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
